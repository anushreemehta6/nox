# Default: local Hardhat (free ETH, no testnet tokens needed)
NEXT_PUBLIC_CHAIN_ID=31337

# PaymentRegistry address (defaults to Hardhat first-deploy address)
NEXT_PUBLIC_PAYMENT_REGISTRY_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3

# Payment amount in wei — default 1 (smallest valid payment)
NEXT_PUBLIC_PAYMENT_AMOUNT_WEI=1

# Receipt API (relay writes receipts; API serves them to the frontend)
NEXT_PUBLIC_RECEIPT_API_URL=http://localhost:3001

# Casper block explorer for settlement links
NEXT_PUBLIC_CASPER_EXPLORER_URL=https://testnet.cspr.live

# For Base Sepolia (when you have testnet ETH):
# NEXT_PUBLIC_CHAIN_ID=84532
# NEXT_PUBLIC_PAYMENT_REGISTRY_ADDRESS=0xYourDeployedAddress
# NEXT_PUBLIC_PAYMENT_AMOUNT_WEI=1
